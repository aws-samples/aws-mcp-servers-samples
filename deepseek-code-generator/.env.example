# DeepSeek Coder Generator MCP Server Configuration

# Required: Your API key for the OpenAI compatible service
OPENAI_API_KEY=your_api_key_here

# Optional: Base URL for the API (default: https://api.deepseek.com)
# For DeepSeek: https://api.deepseek.com
# For OpenAI: https://api.openai.com/v1
# For local APIs: http://localhost:8000/v1
OPENAI_BASE_URL=https://api.deepseek.com

# Optional: Default model to use (default: deepseek-coder)
# For DeepSeek: deepseek-coder, deepseek-chat
# For OpenAI: gpt-4, gpt-3.5-turbo, gpt-4-turbo
DEFAULT_MODEL=deepseek-coder

# Optional: Maximum tokens for responses (default: 4000)
MAX_TOKENS=4000

# Optional: Temperature for code generation (default: 0.1)
# Lower values (0.0-0.3) for more deterministic code generation
# Higher values (0.7-1.0) for more creative solutions
TEMPERATURE=0.1